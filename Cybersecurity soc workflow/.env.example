# Pipeline mode: mock or live
SOC_MODE=mock
DRY_RUN=true
PIPELINE_MAX_ALERTS=5
HTTP_TIMEOUT_SECONDS=30

# Elastic
ELASTIC_BASE_URL=https://localhost:9200
ELASTIC_API_KEY=your_elastic_api_key
ELASTIC_INDEX=.alerts-security.alerts-default
# Optional JSON query file path
# ELASTIC_QUERY_FILE=docs/elastic_query_example.json
ELASTIC_VERIFY_SSL=true

# OpenAI
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Jira
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=SOC
JIRA_ISSUE_TYPE=Task
JIRA_DEFAULT_PRIORITY=Medium
# JIRA_ASSIGNEE_ACCOUNT_ID=12345:abcd-efgh

